import os
import csv
import re
import spacy
from sentence_transformers import SentenceTransformer, util

data_folder = "data" # load data
output_file = "immigration_sentences_semantic.csv"
SIMILARITY_THRESHOLD = 0.45

themes = [
    "immigration policy and border control",
    "refugees and asylum seekers",
    "migrants crossing borders illegally",
    "deportation and detention of migrants",
    "visa systems and citizenship laws",
    "small boats crossing borders"
]

nlp = spacy.load("en_core_web_sm")
model = SentenceTransformer("all-MiniLM-L6-v2")
theme_embeddings = model.encode(themes, convert_to_tensor=True) #load models


with open(output_file, mode="w", newline="", encoding="utf-8") as csv_file: #run semantic search and extract sentences
    writer = csv.writer(csv_file)
    writer.writerow(["party", "year", "text_type", "sentence", "similarity_score"])

    for filename in os.listdir(data_folder):
        if filename.endswith(".txt"):
            name_part = filename.replace(".txt", "")
            parts = name_part.split("_")

            if len(parts) == 3:
                party, text_type, year = parts
            else:
                party = name_part
                text_type = "Unknown"
                year = "Unknown"

            filepath = os.path.join(data_folder, filename)
            with open(filepath, "r", encoding="utf-8") as f:
                text = f.read()

            doc = nlp(text)
            sentences = [sent.text.strip() for sent in doc.sents if sent.text.strip()]

            sent_embeddings = model.encode(sentences, convert_to_tensor=True)

            for i, sent_emb in enumerate(sent_embeddings):
                similarities = util.cos_sim(sent_emb, theme_embeddings)
                max_sim = similarities.max().item()

                if max_sim >= SIMILARITY_THRESHOLD:
                    writer.writerow([
                        party,
                        year,
                        text_type,
                        sentences[i],
                        round(max_sim, 3)
                    ])

print("Done. saved to '{output_file}'") 
